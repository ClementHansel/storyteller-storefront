# ============================================================
# Bambu Silver by Estela — .gitignore
# ============================================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment files with secrets (only .example templates go to git)
.env
.env.local
.env.production
.env.*.local

# VPS reference (contains credentials)
vps_reference.md

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# Testing
coverage/

# Bun (if switching back)
bun.lock
bun.lockb

# Lovable (legacy)
.lovable/

# Misc
*.tgz
*.tsbuildinfo
