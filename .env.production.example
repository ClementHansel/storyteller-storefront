# .env.production — Zenvix Retail Module Template
# ============================================================
# Copy this file to .env.production and fill in your values.
# NEVER commit .env.production to version control.
# All VITE_ prefixed variables are bundled into the client at build time,
# or injected at runtime via the Docker entrypoint script (env-config.js).
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED — The storefront will NOT connect to Zenvix without these.
# If any of these 4 variables is missing or empty, the app falls back
# to mock product data and logs a console warning at startup.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Base URL for the Zenvix Retail Module public API on the VPS.
VITE_ZENVIX_API_URL=http://150.109.15.108:3001/api/retail/public

# Tenant identifier assigned to this storefront in Zenvix.
VITE_ZENVIX_TENANT_ID=

# OAuth client credentials for authenticating API requests.
VITE_ZENVIX_CLIENT_ID=
VITE_ZENVIX_CLIENT_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL (but recommended) — Enables marketing attribution.
# Without this, events are still sent but lack channel tracking.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Links storefront events to the correct marketing channel in Zenvix analytics.
VITE_ZENVIX_CHANNEL_RECORD_ID=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Additional configuration for multi-branch setups
# and alternative auth mechanisms.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Branch identifier (required only for multi-branch tenants).
VITE_ZENVIX_BRANCH_ID=

# Fallback API key used in the X-API-Key header (if OAuth is not configured).
VITE_ZENVIX_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — WhatsApp checkout integration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Office WhatsApp number (digits only, country code + number, e.g. 6281234567890).
# Used to redirect customers to WhatsApp for order confirmation.
VITE_WHATSAPP_OFFICE_PHONE=
