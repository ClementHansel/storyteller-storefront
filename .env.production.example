# .env.production — Zenvix Retail Module Template
# ============================================================
# Copy this file to .env.production and fill in your values.
# NEVER commit this file to version control.
# All VITE_ prefixed variables are bundled into the client.
# Secrets (CLIENT_SECRET) should ideally be handled server-side.
# ============================================================

# ── Zenvix Tenant Credentials ───────────────────────────────
VITE_ZENVIX_TENANT_ID=
VITE_ZENVIX_BRANCH_ID=

# ── Gateway ─────────────────────────────────────────────────
VITE_ZENVIX_GATEWAY_URL=

# ── Auth ────────────────────────────────────────────────────
# Client ID is safe to expose on the frontend.
VITE_ZENVIX_CLIENT_ID=
# Client Secret — use a proxy/BFF endpoint in production to keep this off the client bundle.
VITE_ZENVIX_CLIENT_SECRET=

# ── API Key (fallback auth header) ──────────────────────────
VITE_ZENVIX_API_KEY=

# ── Channel Attribution ─────────────────────────────────────
VITE_ZENVIX_CHANNEL_RECORD_ID=
